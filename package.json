{
  "name": "onyx-mods",
  "version": "0.1.4",
  "description": "Onyx Mods made by swaffX",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/swaffX/onyx-mods"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64 --publish always"
  },
  "build": {
    "appId": "com.swaffx.onyxmods",
    "productName": "Onyx Mods",
    "publish": {
      "provider": "github",
      "owner": "swaffX",
      "repo": "onyx-mods"
    },
    "extraResources": [
      {
        "from": "developer-games.json",
        "to": "developer-games.json"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icons/program_logo.ico"
    }
  },
  "author": "swaffX",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "7zip-bin": "~5.2.0",
    "adm-zip": "^0.5.17",
    "electron-log": "^5.1.2",
    "electron-updater": "^6.8.3",
    "extract-zip": "^2.0.1"
  }
}
